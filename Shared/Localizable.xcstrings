    "Onboarding.CameraAccessDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap to Scan needs your camera to scan barcodes. Tap below to grant access."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バーコードをスキャンするにはカメラが必要です。下のボタンをタップしてアクセスを許可してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u201c点按扫描\u201d需要使用您的相机来扫描条码。请点按下方授予访问权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u300c點按掃描\u300d需要使用您的相機來掃描條碼。請點按下方授予取用權限。"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca para escanear necesita tu cámara para escanear códigos de barras. Toca abajo para conceder acceso."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "바코드를 스캔하려면 카메라가 필요합니다. 아래를 탭하여 접근 권한을 허용하세요."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zum Scannen von Barcodes wird die Kamera benötigt. Tippen Sie unten, um den Zugriff zu erlauben."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toucher pour scanner a besoin de votre caméra pour scanner les codes-barres. Touchez ci-dessous pour autoriser l'accès."
          }
        }
      }
    },
