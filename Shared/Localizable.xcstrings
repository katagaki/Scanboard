    "Onboarding.Subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quickly scan barcodes and copy them to your clipboard. Use the Live Activity to launch the scanner from anywhere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バーコードをすばやくスキャンしてクリップボードにコピーします。ライブアクティビティを使えば、どこからでもスキャナーを起動できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速扫描条码并复制到剪贴板。使用实时活动可从任何位置启动扫描器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速掃描條碼並複製到剪貼簿。使用即時動態可從任何位置啟動掃描器。"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanea códigos de barras rápidamente y cópialos al portapapeles. Usa la Actividad en Vivo para abrir el escáner desde cualquier lugar."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "바코드를 빠르게 스캔하고 클립보드에 복사하세요. 라이브 활동을 사용하면 어디서든 스캐너를 실행할 수 있습니다."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannen Sie Barcodes schnell und kopieren Sie sie in die Zwischenablage. Nutzen Sie die Live-Aktivität, um den Scanner von überall zu starten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannez rapidement des codes-barres et copiez-les dans le presse-papiers. Utilisez l'Activité en direct pour lancer le scanner depuis n'importe où."
          }
        }
      }
    },
